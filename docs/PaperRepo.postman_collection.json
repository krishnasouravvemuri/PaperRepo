            },
            "url": { "raw": "{{base_url}}/important_topic_management/{{topic_id}}/", "host": ["{{base_url}}"], "path": ["important_topic_management", "{{topic_id}}", ""] }
          }
        },
        {
          "name": "Delete Important Topic",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/important_topic_management/{{topic_id}}/", "host": ["{{base_url}}"], "path": ["important_topic_management", "{{topic_id}}", ""] }
          }
        }
      ]
    },
    {
      "name": "Material Management",
      "item": [
