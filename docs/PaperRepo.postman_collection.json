                { "key": "subject_code", "value": "CSE101", "type": "text" },
                { "key": "subject_name", "value": "Intro CS", "type": "text" },
                { "key": "material_topic_type", "value": "Notes", "type": "text" },
                { "key": "faculty_name", "value": "Dr Y", "type": "text", "description": "optional" },
                { "key": "files", "type": "file", "src": [], "description": "one or more files; required" }
              ]
